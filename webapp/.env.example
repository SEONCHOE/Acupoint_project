# 이 파일을 복사해서 webapp/.env 를 만들고 실제 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 에 의해 커밋되지 않습니다. 실제 키를 절대 커밋하지 마세요.

# 네이버 클라우드 플랫폼 CLOVA Speech Recognition (CSR)
NCP_CLOVA_CLIENT_ID=your-client-id-here
NCP_CLOVA_CLIENT_SECRET=your-client-secret-here

# Flask 시크릿 (운영 환경에서는 반드시 임의의 강한 값으로 교체)
FLASK_SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-a-random-secret
